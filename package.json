{
  "name": "jupyter-dremio",
  "version": "0.1.11",
  "description": "JupyterLab extension for browsing the Dremio catalog",
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension",
    "dremio"
  ],
  "homepage": "https://github.com/your-org/jupyter-dremio",
  "bugs": {
    "url": "https://github.com/your-org/jupyter-dremio/issues"
  },
  "license": "BSD-3-Clause",
  "author": {
    "name": "Your Organization",
    "email": "you@example.com"
  },
  "files": [
    "lib/**/*.{d.ts,eot,gif,html,jpg,js,js.map,json,png,svg,woff2,ttf}",
    "style/**/*.{css,js,eot,gif,html,jpg,json,png,svg,woff2,ttf}",
    "schema/*.json"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/jupyter-dremio.git"
  },
  "scripts": {
    "build": "jlpm build:lib && jlpm build:labextension:dev",
    "build:prod": "jlpm clean && jlpm build:lib:prod && jlpm build:labextension",
    "build:labextension": "jupyter labextension build .",
    "build:labextension:dev": "jupyter labextension build --development True .",
    "build:lib": "tsc --sourceMap",
    "build:lib:prod": "tsc",
    "clean": "jlpm clean:lib && jlpm clean:labextension && jlpm clean:lintcache",
    "clean:lib": "node -e \"['lib','tsconfig.tsbuildinfo'].forEach(p=>{require('fs').rmSync(p,{recursive:true,force:true})})\"",
    "clean:labextension": "node -e \"['jupyter_dremio/labextension','jupyter_dremio/_version.py'].forEach(p=>{try{require('fs').rmSync(p,{recursive:true,force:true})}catch(_){}})\"",
    "clean:lintcache": "node -e \"['.eslintcache','.stylelintcache'].forEach(p=>{try{require('fs').rmSync(p,{force:true})}catch(_){}})\"",
    "install:extension": "jlpm build:lib && jlpm build:labextension:dev",
    "lint": "jlpm eslint && jlpm stylelint && jlpm prettier:check",
    "watch": "run-p watch:src watch:labextension",
    "watch:src": "tsc -w --sourceMap",
    "watch:labextension": "jupyter labextension watch ."
  },
  "dependencies": {
    "@jupyterlab/application": "^4.0.0",
    "@jupyterlab/apputils": "^4.0.0",
    "@jupyterlab/notebook": "^4.0.0",
    "@jupyterlab/ui-components": "^4.0.0",
    "@lumino/messaging": "^2.0.0",
    "@lumino/widgets": "^2.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.0.2"
  },
  "sideEffects": [
    "style/*.css",
    "style/index.js"
  ],
  "styleModule": "style/index.js",
  "jupyterlab": {
    "extension": true,
    "outputDir": "jupyter_dremio/labextension",
    "schemaDir": "schema"
  },
  "jupyter-releaser": {
    "hooks": {
      "before-build-npm": [
        "python -m pip install jupyterlab",
        "jlpm"
      ],
      "before-build-python": [
        "jlpm clean",
        "jlpm build:prod"
      ]
    }
  }
}
